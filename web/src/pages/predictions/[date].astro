---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteShell from "../../components/SiteShell.astro";
import StatusPill from "../../components/StatusPill.astro";
import StockLink from "../../components/StockLink.astro";
import {
  formatDisplayDate,
  formatSignedPercent,
  loadPredictionDetail,
} from "../../lib/predictions.mjs";

const date = Astro.params.date;
const detail = date ? await loadPredictionDetail(date) : null;

function toneClass(value) {
  if (value === null || value === undefined || Number.isNaN(Number(value))) {
    return "tone-neutral";
  }
  return Number(value) >= 0 ? "tone-positive" : "tone-negative";
}

if (!detail) {
  Astro.response.status = 404;
}
---

<BaseLayout title={`Quant Briefing | ${date ?? "未找到"}`} description="单日预测详情">
  <SiteShell
    eyebrow="Single Day Detail"
    title={detail ? formatDisplayDate(detail.as_of_date) : "预测不存在"}
    subtitle={detail ? "候选排序、入出场设定与验证指标都在这一页。" : "没有找到对应日期的 canonical 预测文件。"}
  >
    {
      detail ? (
        <>
          <a class="back-link" href="/history">← 返回历史列表</a>
          <div class="detail-grid">
            <section class="card">
              <StatusPill status={detail.status} />
              <div class="ticker">
                <StockLink code={detail.selected?.code ?? detail.selected_code} className="ticker-link" />
              </div>
              <p class="score-line">模型分数 {detail.selected?.score?.toFixed(4) ?? detail.selected_score?.toFixed(4)}</p>
              <div class="definition-list">
                <div class="definition-item">
                  <span class="muted-label">入场</span>
                  <div>{detail.entry_date}</div>
                </div>
                <div class="definition-item">
                  <span class="muted-label">出场</span>
                  <div>{detail.exit_date}</div>
                </div>
                <div class="definition-item">
                  <span class="muted-label">候选池规模</span>
                  <div>{detail.universe_size}</div>
                </div>
                <div class="definition-item">
                  <span class="muted-label">模型版本</span>
                  <div>{detail.prediction_name}</div>
                </div>
              </div>
            </section>

            <section class="card">
              <h2>验证结果</h2>
              <div class="metrics-grid">
                <div>
                  <span class="muted-label">选中收益</span>
                  <p class={`metric-value ${toneClass(detail.summary?.selected_return)}`}>
                    {formatSignedPercent(detail.summary?.selected_return)}
                  </p>
                </div>
                <div>
                  <span class="muted-label">Alpha</span>
                  <p class={`metric-value ${toneClass(detail.summary?.alpha)}`}>
                    {formatSignedPercent(detail.summary?.alpha)}
                  </p>
                </div>
                <div>
                  <span class="muted-label">Oracle</span>
                  <p class={`metric-value ${toneClass(detail.summary?.oracle_return)}`}>
                    {formatSignedPercent(detail.summary?.oracle_return)}
                  </p>
                </div>
              </div>
              {
                detail.validation ? (
                  <p>
                    全市场均值 {formatSignedPercent(detail.validation.universe_return)}，命中结果
                    {detail.validation.hit ? "为正" : "未命中"}。
                  </p>
                ) : (
                  <p>该条预测还没有足够的未来标签，因此验证仍处于待完成状态。</p>
                )
              }
            </section>
          </div>

          <section class="card">
            <h2>Top 候选</h2>
            <div class="candidate-grid">
              {(detail.top_candidates ?? []).map((item) => (
                <div class="candidate-item">
                  <span class="candidate-rank">Rank {item.rank}</span>
                  <span class="candidate-code">
                    <StockLink code={item.code} />
                  </span>
                  <span>{item.score?.toFixed(4)}</span>
                </div>
              ))}
            </div>
          </section>
        </>
      ) : (
        <section class="card empty-state">
          <h2>没有找到这个交易日</h2>
          <p>请确认 `artifacts/predictions/daily/{date}.json` 是否存在。</p>
        </section>
      )
    }
  </SiteShell>
</BaseLayout>
