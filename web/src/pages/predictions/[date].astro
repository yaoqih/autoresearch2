---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteShell from "../../components/SiteShell.astro";
import StatusPill from "../../components/StatusPill.astro";
import StockLink from "../../components/StockLink.astro";
import {
  displayPrimaryCode,
  executionSummary,
  formatDisplayDate,
  formatSignedPercent,
  loadPredictionDetail,
} from "../../lib/predictions.mjs";

const date = Astro.params.date;
const detail = date ? await loadPredictionDetail(date) : null;
const execution = detail ? executionSummary(detail) : null;
const executedCode = detail ? displayPrimaryCode(detail) : null;
const executedScore = detail?.validation?.executed_score ?? detail?.selected?.score ?? detail?.selected_score ?? null;

function toneClass(value) {
  if (value === null || value === undefined || Number.isNaN(Number(value))) {
    return "tone-neutral";
  }
  return Number(value) >= 0 ? "tone-positive" : "tone-negative";
}

if (!detail) {
  Astro.response.status = 404;
}
---

<BaseLayout title={`Quant Briefing | ${date ?? "未找到"}`} description="单日预测详情">
  <SiteShell
    eyebrow="Single Day Detail"
    title={detail ? formatDisplayDate(detail.as_of_date) : "预测不存在"}
    subtitle={detail ? "模型排序和实际执行拆开展示，回填窗口内的每一名候选都可查看真实收益与可交易状态。" : "没有找到对应日期的 canonical 预测文件。"}
  >
    {
      detail ? (
        <>
          <a class="back-link" href="/history">← 返回历史列表</a>
          <div class="detail-grid">
            <section class="card">
              <span class="muted-label">Model Top1</span>
              <StatusPill status={detail.status} />
              <div class="ticker">
                <StockLink code={detail.selected?.code ?? detail.selected_code} className="ticker-link" />
              </div>
              <p class="score-line">模型分数 {detail.selected?.score?.toFixed(4) ?? detail.selected_score?.toFixed(4)}</p>
              <div class="definition-list">
                <div class="definition-item">
                  <span class="muted-label">入场</span>
                  <div>{detail.entry_date}</div>
                </div>
                <div class="definition-item">
                  <span class="muted-label">出场</span>
                  <div>{detail.exit_date}</div>
                </div>
                <div class="definition-item">
                  <span class="muted-label">候选池规模</span>
                  <div>{detail.universe_size}</div>
                </div>
                <div class="definition-item">
                  <span class="muted-label">模型版本</span>
                  <div>{detail.prediction_name}</div>
                </div>
              </div>
            </section>

            <section class="card">
              <span class="muted-label">Executed Outcome</span>
              <h2 class="execution-headline">
                {
                  detail.validation ? (
                    execution?.allFallbackBlocked ? "未成交" : <StockLink code={executedCode} className="ticker-link" />
                  ) : (
                    "待验证"
                  )
                }
              </h2>
              <p class="score-line">
                {
                  detail.validation
                    ? execution?.allFallbackBlocked
                      ? (execution?.fallbackWindowSize ?? 10) <= 1
                        ? "Top1 开盘涨停，收益按 0 记"
                        : `Top${execution?.fallbackWindowSize ?? 10} 全部开盘涨停，收益按 0 记`
                      : `执行分数 ${executedScore?.toFixed(4) ?? "N/A"}`
                    : "该交易日还没有足够的未来标签，尚未回填执行结果。"
                }
              </p>
              <div class="metrics-grid">
                <div>
                  <span class="muted-label">策略收益</span>
                  <p class={`metric-value ${toneClass(detail.summary?.selected_return)}`}>
                    {formatSignedPercent(detail.summary?.selected_return)}
                  </p>
                </div>
                <div>
                  <span class="muted-label">Alpha</span>
                  <p class={`metric-value ${toneClass(detail.summary?.alpha)}`}>
                    {formatSignedPercent(detail.summary?.alpha)}
                  </p>
                </div>
                <div>
                  <span class="muted-label">执行排名</span>
                  <p class="metric-value tone-neutral">
                    {detail.validation ? (execution?.executedRank ?? "无") : "待"}
                  </p>
                </div>
              </div>
              {
                detail.validation ? (
                  execution?.allFallbackBlocked ? (
                    (execution?.fallbackWindowSize ?? 10) <= 1 ? (
                      <p class="execution-note">模型 Top1 为 <StockLink code={execution?.modelCode} />，且开盘已买不进，因此当天不成交。</p>
                    ) : (
                      <p class="execution-note">模型 Top1 为 <StockLink code={execution?.modelCode} />，但 Top{execution?.fallbackWindowSize ?? 10} 全部开盘涨停，因此当天不成交。</p>
                    )
                  ) : execution?.fallbackApplied ? (
                    <p class="execution-note">模型 Top1 <StockLink code={execution?.modelCode} /> 开盘涨停，实际顺延至 Rank {execution?.executedRank} 的 <StockLink code={executedCode} />。</p>
                  ) : (
                    <p class="execution-note">模型 Top1 直接成交，全市场均值 {formatSignedPercent(detail.validation.universe_return)}。</p>
                  )
                ) : (
                  <p>该条预测还没有足够的未来标签，因此验证仍处于待完成状态。</p>
                )
              }
            </section>
          </div>

          <section class="card">
            <div class="section-heading">
              <div>
                <span class="muted-label">Candidate Audit Trail</span>
                <h2>候选回填</h2>
              </div>
              <p>每行同时给出模型分数、实际收益、理想收益，以及是否因开盘涨停被挡掉。</p>
            </div>
            <div class="candidate-table">
              <div class="candidate-table-head">
                <span>Rank</span>
                <span>股票</span>
                <span>分数</span>
                <span>实际收益</span>
                <span>理想收益</span>
                <span>开盘涨停</span>
                <span>执行</span>
              </div>
              {(detail.top_candidates ?? []).map((item) => (
                <div class={`candidate-table-row ${item.validation?.executed ? "candidate-executed" : ""}`}>
                  <span class="candidate-rank">#{item.rank}</span>
                  <span class="candidate-code"><StockLink code={item.code} /></span>
                  <span>{item.score?.toFixed(4)}</span>
                  <span class={toneClass(item.validation?.strict_open_return)}>
                    {formatSignedPercent(item.validation?.strict_open_return)}
                  </span>
                  <span class={toneClass(item.validation?.ideal_return)}>
                    {formatSignedPercent(item.validation?.ideal_return)}
                  </span>
                  <span>{item.validation ? (item.validation.open_limit_day1 ? "是" : "否") : "待验证"}</span>
                  <span>
                    {item.validation ? (item.validation.executed ? "已执行" : item.validation.tradeable ? "可成交" : "被挡") : "待验证"}
                  </span>
                </div>
              ))}
            </div>
          </section>
        </>
      ) : (
        <section class="card empty-state">
          <h2>没有找到这个交易日</h2>
          <p>请确认 `artifacts/predictions/daily/{date}.json` 是否存在。</p>
        </section>
      )
    }
  </SiteShell>
</BaseLayout>
